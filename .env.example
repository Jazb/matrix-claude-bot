# ─── Required ─────────────────────────────────────────────────────────────────

# Matrix homeserver URL
MATRIX_HOMESERVER_URL=https://matrix.example.com

# Bot access token (obtain via Element login or `matrix-bot-sdk` MatrixAuth)
MATRIX_ACCESS_TOKEN=syt_your_access_token_here

# Your Matrix user ID — only this user can interact with the bot
MATRIX_ALLOWED_USER_ID=@youruser:example.com

# Projects: comma-separated "name=/absolute/path" pairs
PROJECTS=myproject=/home/user/myproject,other=/home/user/other

# Claude auth (one of these, depending on your setup)
CLAUDE_CODE_OAUTH_TOKEN=your_oauth_token
# ANTHROPIC_API_KEY=sk-ant-your-key

# ─── Optional (with defaults) ────────────────────────────────────────────────

# Matrix account password — required for cross-signing bootstrap
# MATRIX_PASSWORD=your_matrix_password

# E2EE (enabled by default)
# MATRIX_ENABLE_E2EE=true
# MATRIX_CRYPTO_STORAGE_PATH=./data/crypto

# Groq API key for voice transcription (optional, https://console.groq.com/keys)
# GROQ_API_KEY=gsk_your_groq_api_key_here
# GROQ_MODEL=whisper-large-v3-turbo
# GROQ_ENDPOINT=https://api.groq.com/openai/v1/audio/transcriptions
# GROQ_LANGUAGE=auto

# DEFAULT_PROJECT=myproject
# CLAUDE_BINARY_PATH=/usr/bin/claude
# CLAUDE_TIMEOUT=300000
# CLAUDE_MAX_TURNS=25
# MAX_MESSAGE_LENGTH=4096
# TMP_DIR=/tmp/matrix-claude-bot
# SESSIONS_FILE=./data/sessions.json
# LOG_LEVEL=info                # "debug" to see SDK logs on stderr

# ─── Operating Mode ─────────────────────────────────────────────────────────

# BOT_MODE=bot               # "bot" (one-shot subprocess, default)
#                             # "bridge" (tmux + hooks, requires tmux)
#                             # "ide" (MCP WebSocket protocol, recommended for interactivity)
# CLAUDE_EXTRA_ARGS=          # Extra args for claude in bridge/ide mode (e.g. "--model,sonnet")
# BRIDGE_SOCKET_DIR=/tmp      # Directory for IPC Unix socket files (bridge mode)
# BRIDGE_HOOK_TIMEOUT=10000   # Hook timeout in ms (bridge mode)
